#!/bin/sh
set -eu

config="${XDG_CONFIG_HOME:-$HOME/.config}/niri/config.kdl"
state_file="${XDG_STATE_HOME:-$HOME/.local/state}/niri/open-workspace-rules"
marker="niri-toggle-open-workspace-rules:"

if [ -f "$state_file" ]; then
    state="$(cat "$state_file")"
elif grep -q "^// $marker" "$config"; then
    state="disabled"
else
    state="enabled"
fi

case "$state" in
    disabled)
        printf '{"text":"","class":"disabled","tooltip":"App workspace rules disabled"}\n'
        ;;
    *)
        printf '{"text":"","class":"enabled","tooltip":"App workspace rules enabled"}\n'
        ;;
esac
