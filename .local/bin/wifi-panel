#!/usr/bin/env python3

import subprocess
import sys
from pathlib import Path

from wofi_focus import run_wofi_menu


PANEL_STYLE = str(Path.home() / ".config/wofi/panel.css")
PANEL_ARGS = [
    "wofi",
    "--show",
    "dmenu",
    "--location",
    "top_left",
    "--xoffset",
    "10",
    "--yoffset",
    "8",
    "--width",
    "344",
    "--height",
    "300",
    "--style",
    PANEL_STYLE,
    "--prompt",
    "Wi-Fi",
    "--hide-search",
    "--insensitive",
    "--gtk-dark",
    "--cache-file",
    "/dev/null",
]

SEPARATOR = "──────── Networks ────────"


def run(cmd, check=True):
    return subprocess.run(cmd, capture_output=True, text=True, check=check)


def notify(message, title="Wi-Fi"):
    subprocess.run(["notify-send", title, message], check=False)


def wofi_command(prompt):
    cmd = PANEL_ARGS[:]
    cmd[16] = prompt
    return cmd


def menu(prompt, lines):
    if not lines:
        return None
    return run_wofi_menu(wofi_command(prompt), "\n".join(lines) + "\n")


def password_prompt(ssid):
    proc = subprocess.run(
        ["zenity", "--password", f"--title=Wi-Fi: {ssid}"],
        text=True,
        capture_output=True,
        check=False,
    )
    if proc.returncode != 0:
        return None
    return proc.stdout.strip()


def wifi_enabled():
    proc = run(["nmcli", "radio", "wifi"], check=False)
    return proc.returncode == 0 and proc.stdout.strip().lower() == "enabled"


def current_connection():
    proc = run(
        ["nmcli", "-t", "--escape", "no", "-f", "ACTIVE,SSID,SIGNAL", "dev", "wifi", "list", "--rescan", "no"],
        check=False,
    )
    for line in proc.stdout.splitlines():
        parts = line.split(":")
        if len(parts) >= 3 and parts[0] == "yes":
            return parts[1], parts[2]
    return None, None


def wifi_entries():
    proc = run(
        [
            "nmcli",
            "-t",
            "--escape",
            "no",
            "-f",
            "IN-USE,SSID,SIGNAL,SECURITY,BARS",
            "device",
            "wifi",
            "list",
            "--rescan",
            "no",
        ],
        check=False,
    )
    entries = []
    seen = set()
    for line in proc.stdout.splitlines():
        parts = line.split(":")
        if len(parts) < 5:
            continue
        in_use, ssid, signal, security, bars = parts[:5]
        ssid = "<hidden>" if ssid in {"", "--"} else ssid
        security = "Open" if security in {"", "--"} else security
        active = in_use == "*"
        key = (ssid, security)
        if key in seen:
            continue
        seen.add(key)

        status_icon = "󰖩" if active else "󰖪"
        lock_icon = "󰌾" if security != "Open" else "󰌿"
        label = f"{status_icon}  {ssid}   {signal}% {bars}   {lock_icon} {security}"
        entries.append(
            {
                "label": label,
                "ssid": ssid,
                "security": security,
                "active": active,
            }
        )
    return entries


def connect_network(entry):
    ssid = entry["ssid"]
    security = entry["security"].lower()

    cmd = ["nmcli", "device", "wifi", "connect", ssid]
    if security != "open":
        password = password_prompt(ssid)
        if password is None:
            return
        cmd += ["password", password]

    proc = run(cmd, check=False)
    if proc.returncode == 0:
        notify(f"Connected to {ssid}")
        return

    stderr = (proc.stderr or proc.stdout).strip()
    notify(stderr or f"Failed to connect to {ssid}", "Wi-Fi Error")


def disconnect_active():
    proc = run(
        ["nmcli", "-t", "-f", "DEVICE,TYPE,STATE", "device"],
        check=False,
    )
    for line in proc.stdout.splitlines():
        parts = line.split(":")
        if len(parts) >= 3 and parts[1] == "wifi" and parts[2] == "connected":
            device = parts[0]
            out = run(["nmcli", "device", "disconnect", device], check=False)
            if out.returncode == 0:
                notify("Wi-Fi disconnected")
            else:
                notify((out.stderr or out.stdout).strip() or "Disconnect failed", "Wi-Fi Error")
            return
    notify("No active Wi-Fi connection")


def main():
    enabled = wifi_enabled()
    current_ssid, current_signal = current_connection()

    lines = []
    if enabled:
        if current_ssid:
            lines.append(f"󰖩  {current_ssid} connected   {current_signal}%")
        else:
            lines.append("󰖪  Not connected")
        lines.append("󰑐  Refresh networks")
        lines.append("󰖪  Disconnect")
        lines.append("󰤮  Turn Wi-Fi off")
        lines.append(SEPARATOR)
        for entry in wifi_entries():
            lines.append(entry["label"])
    else:
        lines.append("󰤨  Turn Wi-Fi on")

    choice = menu("Wi-Fi", lines)
    if not choice:
        return

    if choice == "󰤨  Turn Wi-Fi on":
        run(["nmcli", "radio", "wifi", "on"], check=False)
        notify("Wi-Fi enabled")
        return
    if choice == "󰤮  Turn Wi-Fi off":
        run(["nmcli", "radio", "wifi", "off"], check=False)
        notify("Wi-Fi disabled")
        return
    if choice == "󰑐  Refresh networks":
        run(["nmcli", "device", "wifi", "rescan"], check=False)
        subprocess.run([sys.argv[0]], check=False)
        return
    if choice == "󰖪  Disconnect":
        disconnect_active()
        return
    if choice == SEPARATOR or choice.startswith("󰖩  ") or choice == "󰖪  Not connected":
        return

    for entry in wifi_entries():
        if entry["label"] == choice:
            if entry["active"]:
                disconnect_active()
            else:
                connect_network(entry)
            return

    notify(f"Unknown selection: {choice}", "Wi-Fi Error")


if __name__ == "__main__":
    main()
