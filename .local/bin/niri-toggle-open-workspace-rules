#!/bin/sh
set -eu

config="${XDG_CONFIG_HOME:-$HOME/.config}/niri/config.kdl"
state_dir="${XDG_STATE_HOME:-$HOME/.local/state}/niri"
state_file="$state_dir/open-workspace-rules"
marker="niri-toggle-open-workspace-rules:"

mkdir -p "$state_dir"

if grep -q "^// $marker" "$config"; then
    perl -0pi -e 's|^// niri-toggle-open-workspace-rules: ([ \t]*open-on-workspace "[^"]+")$|$1|mg' "$config"
    printf '%s\n' enabled > "$state_file"
    command -v notify-send >/dev/null 2>&1 && notify-send "niri" "App workspace rules enabled" 2>/dev/null || true
else
    perl -0pi -e 's|^([ \t]*open-on-workspace "[^"]+")$|// niri-toggle-open-workspace-rules: $1|mg' "$config"
    printf '%s\n' disabled > "$state_file"
    command -v notify-send >/dev/null 2>&1 && notify-send "niri" "App workspace rules disabled" 2>/dev/null || true
fi

pkill -RTMIN+8 waybar 2>/dev/null || true
