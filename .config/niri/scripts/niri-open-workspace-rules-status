#!/usr/bin/env python3
import json
import os
from pathlib import Path


HOME = Path.home()
CONFIG = Path(os.environ.get("XDG_CONFIG_HOME", HOME / ".config")) / "niri" / "config.kdl"
STATE_FILE = Path(os.environ.get("XDG_STATE_HOME", HOME / ".local" / "state")) / "niri" / "open-workspace-rules"
MARKER = "niri-toggle-open-workspace-rules:"


def current_state() -> str:
    if STATE_FILE.exists():
        return STATE_FILE.read_text().strip()

    if CONFIG.exists():
        for line in CONFIG.read_text().splitlines():
            if line.startswith(f"// {MARKER}"):
                return "disabled"

    return "enabled"


def main() -> int:
    if current_state() == "disabled":
        payload = {
            "text": "",
            "class": "disabled",
            "tooltip": "App workspace rules disabled",
        }
    else:
        payload = {
            "text": "",
            "class": "enabled",
            "tooltip": "App workspace rules enabled",
        }

    print(json.dumps(payload, ensure_ascii=False, separators=(",", ":")))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
