// Animations
animations {
    slowdown 1.3

    workspace-switch {
        spring damping-ratio=1.0 stiffness=700 epsilon=0.0001
    }

    horizontal-view-movement {
        spring damping-ratio=1.0 stiffness=700 epsilon=0.0001
    }

    window-open {
        duration-ms 180
        curve "ease-out-expo"
    }

    window-close {
        duration-ms 160
        curve "ease-out-quad"
    }
}

